PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/aijob?retryWrites=true&w=majority

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cron Schedule
SCRAPER_CRON=0 */6 * * *
CLEANUP_CRON=0 2 * * *

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# CORS
ALLOWED_ORIGINS=http://localhost:3000
